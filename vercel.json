{
    "version": 2,
    "builds": [
      {
        "src": "backend/server.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "backend/server.js"
      },
      {
        "src": "/(.*)",
        "dest": "backend/server.js",
        "headers": {
          "Cache-Control": "no-cache, no-store, must-revalidate"
        }
      }
    ]
  }
